<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Yii2">
    <rule ref="vendor/yiisoft/yii2-coding-standards/Yii2"></rule>

    <!-- generate relative paths -->
    <arg name="basepath" value="."/>

    <!-- directories to check -->
    <file>assets</file>
    <file>commands</file>
    <file>controllers</file>
    <file>mail</file>
    <file>models</file>
    <file>tests</file>
</ruleset>
